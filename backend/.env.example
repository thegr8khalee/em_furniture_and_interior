# =============================================
# EM Furniture & Interior — Backend Environment
# =============================================

# --- App ---
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173

# --- Database ---
MONGODB_URI=mongodb://localhost:27017/em_furniture

# --- Auth ---
JWT_SECRET=change_me_to_a_strong_random_string

# --- Cloudinary (image hosting) ---
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Gmail OAuth2 (email sending) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://developers.google.com/oauthplayground
GOOGLE_REFRESH_TOKEN=
EMAIL_USER=emfurnitureandinterior@gmail.com

# --- Payment gateways ---
PAYSTACK_SECRET_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_CURRENCY=NGN
STRIPE_SECRET_KEY=
STRIPE_CURRENCY=NGN

# --- Tax ---
TAX_RATE_PERCENTAGE=7.5

# --- Seed (optional) ---
SEED_ADMIN_PASSWORD=ChangeMe123!
